{
  "name": "Elastic AgentCore",
  "image": "mcr.microsoft.com/devcontainers/python:3.13",
  "features": {
    "ghcr.io/devcontainers/features/aws-cli:1": {}
  },
  "postCreateCommand": "bash setup.sh",
  "forwardPorts": [8501],
  "portsAttributes": {
    "8501": {
      "label": "Streamlit UI",
      "onAutoForward": "openBrowser"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python"]
    }
  }
}
