# =============================================================================
# Elastic Cloud Serverless
# =============================================================================
# Your Kibana URL (from Elastic Cloud console → your project → Endpoints)
KIBANA_URL=

# Elasticsearch URL (for the API key creation script only)
ELASTICSEARCH_URL=

# API key created with Agent Builder MCP permissions (base64-encoded)
ELASTIC_API_KEY=

# =============================================================================
# AWS Configuration
# =============================================================================
AWS_REGION=us-east-1

# =============================================================================
# AgentCore Memory (populated after running scripts/setup_memory.py)
# =============================================================================
MEMORY_ID=

# =============================================================================
# AgentCore Runtime (populated after deploying with `agentcore launch`)
# =============================================================================
AGENT_RUNTIME_ARN=

# =============================================================================
# Elasticsearch Memory (optional -- enables store_memory / recall_memories tools)
# Set the index name to enable; leave blank to disable.
# Create the index first: uv run python -m scripts.setup_memory_index
# =============================================================================
ES_MEMORY_INDEX=
